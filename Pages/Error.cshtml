@page
@model LMSDashboard.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card border-0 shadow-sm">
            <div class="card-body py-5">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
                <h2 class="mt-3">Something went wrong</h2>

                @if (Model.ShowRequestId)
                {
                    <p class="text-muted small">
                        Request ID: <code>@Model.RequestId</code>
                    </p>
                }

                <p class="text-muted">
                    An unexpected error occurred. Please try again or contact your administrator.
                </p>

                <a href="/Dashboard" class="btn btn-primary mt-2">
                    <i class="bi bi-house me-1"></i>Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
