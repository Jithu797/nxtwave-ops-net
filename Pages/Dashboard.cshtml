@page
@model LMSDashboard.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<h2 class="mb-4"><i class="bi bi-speedometer2 me-2 text-primary"></i>Operations Dashboard</h2>

<!-- Metric Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                    <i class="bi bi-collection-fill fs-4 text-primary"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Items</div>
                    <div class="fs-3 fw-bold">@Model.TotalItems</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                    <i class="bi bi-hourglass-split fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">In Beta</div>
                    <div class="fs-3 fw-bold">@Model.InBeta</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-info bg-opacity-10 p-3 me-3">
                    <i class="bi bi-check-circle-fill fs-4 text-info"></i>
                </div>
                <div>
                    <div class="text-muted small">Validated</div>
                    <div class="fs-3 fw-bold">@Model.Validated</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                    <i class="bi bi-rocket-takeoff-fill fs-4 text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">In Production</div>
                    <div class="fs-3 fw-bold">@Model.InProduction</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Status Pipeline Chart -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-semibold">Status Pipeline</div>
            <div class="card-body">
                <canvas id="statusChart" height="220"></canvas>
            </div>
        </div>
    </div>
    <!-- Track Distribution Chart -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-semibold">Content by Track</div>
            <div class="card-body">
                <canvas id="trackChart" height="220"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Recent Items Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent fw-semibold d-flex justify-content-between align-items-center">
        <span>Recent Content Items</span>
        <a href="/Content" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Track</th>
                        <th>Difficulty</th>
                        <th>Status</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentItems)
                    {
                        <tr>
                            <td class="fw-medium">@item.Title</td>
                            <td><span class="badge bg-secondary">@item.Type</span></td>
                            <td>@item.Track</td>
                            <td>@item.Difficulty</td>
                            <td>
                                <span class="badge @StatusBadgeClass(item.Status)">@item.Status</span>
                            </td>
                            <td class="text-muted small">@item.CreatedAt.ToString("MMM d, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    string StatusBadgeClass(string status) => status switch
    {
        "Pending" => "bg-secondary",
        "InBeta" => "bg-warning text-dark",
        "Validated" => "bg-info text-dark",
        "InProduction" => "bg-success",
        "Failed" => "bg-danger",
        _ => "bg-secondary"
    };
}

@section Scripts {
<script>
    const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusCounts));
    const trackData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrackCounts));

    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: Object.keys(statusData),
            datasets: [{ data: Object.values(statusData), backgroundColor: ['#6c757d','#ffc107','#0dcaf0','#198754','#dc3545'] }]
        },
        options: { plugins: { legend: { position: 'bottom' } } }
    });

    new Chart(document.getElementById('trackChart'), {
        type: 'bar',
        data: {
            labels: Object.keys(trackData),
            datasets: [{ label: 'Items', data: Object.values(trackData), backgroundColor: '#0d6efd' }]
        },
        options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
    });
</script>
}
