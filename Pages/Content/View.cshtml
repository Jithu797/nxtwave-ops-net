@page "{id:guid}"
@model LMSDashboard.Pages.Content.ViewModel
@{
    ViewData["Title"] = Model.Item?.Title ?? "Content Item";
    ViewData["ActivePage"] = "Content";
}

@if (Model.Item == null)
{
    <div class="alert alert-danger">Item not found.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@Model.Item.Title</h2>
        <a href="/Content" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent fw-semibold">Item Details</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8 text-muted small">@Model.Item.Id</dd>
                        <dt class="col-sm-4">Type</dt>
                        <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Item.Type</span></dd>
                        <dt class="col-sm-4">Track</dt>
                        <dd class="col-sm-8">@Model.Item.Track</dd>
                        <dt class="col-sm-4">Difficulty</dt>
                        <dd class="col-sm-8">@Model.Item.Difficulty</dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge @StatusBadge(Model.Item.Status)">@Model.Item.Status</span>
                        </dd>
                        <dt class="col-sm-4">Created By</dt>
                        <dd class="col-sm-8">@Model.Item.CreatedBy</dd>
                        <dt class="col-sm-4">Created At</dt>
                        <dd class="col-sm-8 text-muted small">@Model.Item.CreatedAt.ToString("MMM d, yyyy HH:mm")</dd>
                        @if (Model.Item.BetaUploadedAt.HasValue)
                        {
                            <dt class="col-sm-4">Beta Upload</dt>
                            <dd class="col-sm-8 text-muted small">@Model.Item.BetaUploadedAt.Value.ToString("MMM d, yyyy HH:mm")</dd>
                        }
                        @if (Model.Item.ProdUploadedAt.HasValue)
                        {
                            <dt class="col-sm-4">Prod Upload</dt>
                            <dd class="col-sm-8 text-muted small">@Model.Item.ProdUploadedAt.Value.ToString("MMM d, yyyy HH:mm")</dd>
                        }
                        @if (!string.IsNullOrEmpty(Model.Item.Notes))
                        {
                            <dt class="col-sm-4">Notes</dt>
                            <dd class="col-sm-8">@Model.Item.Notes</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent fw-semibold d-flex justify-content-between">
                    <span>Validation Logs</span>
                    <form method="post">
                        <input type="hidden" name="id" value="@Model.Item.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-check2-circle me-1"></i>Run Validation
                        </button>
                    </form>
                </div>
                <div class="card-body p-0">
                    @if (Model.Item.ValidationLogs == null || !Model.Item.ValidationLogs.Any())
                    {
                        <div class="p-3 text-muted">No validation logs yet.</div>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr><th>Rule</th><th>Result</th><th>Message</th><th>Checked</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.Item.ValidationLogs.OrderByDescending(v => v.CheckedAt).Take(20))
                                {
                                    <tr>
                                        <td class="small">@log.RuleName</td>
                                        <td>
                                            <span class="badge @(log.Result == "Pass" ? "bg-success" : "bg-danger")">
                                                @log.Result
                                            </span>
                                        </td>
                                        <td class="small text-muted">@log.Message</td>
                                        <td class="small text-muted">@log.CheckedAt.ToString("HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
}

@functions {
    string StatusBadge(string status) => status switch
    {
        "Pending" => "bg-secondary",
        "InBeta" => "bg-warning text-dark",
        "Validated" => "bg-info text-dark",
        "InProduction" => "bg-success",
        "Failed" => "bg-danger",
        _ => "bg-secondary"
    };
}
