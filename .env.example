# Database
ConnectionStrings__DefaultConnection=Server=(localdb)\mssqllocaldb;Database=LMSDashboard;Trusted_Connection=True;

# JWT
Jwt__Secret=YOUR_SECRET_KEY_MIN_32_CHARACTERS_HERE
Jwt__Issuer=LMSDashboard
Jwt__Audience=LMSDashboard

# Dev Auth (replace with real identity provider in production)
Auth__DevUsername=admin
Auth__DevPassword=admin123

# Google Sheets Integration
GoogleSheets__Enabled=false
GoogleSheets__SpreadsheetId=YOUR_SPREADSHEET_ID
GoogleSheets__SheetName=LMSContent
GoogleSheets__CredentialsPath=credentials/google-service-account.json

# AI Microservice
AiService__BaseUrl=http://localhost:8001
